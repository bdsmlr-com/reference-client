  "links": {
    "defaults": {
      "internalTarget": "_self",
      "externalTarget": "_blank",
      "externalRel": [
        "noopener",
        "noreferrer"
      ]
    },
    "contexts": {
      "nav_logo": {
        "mode": "internal",
        "pattern": "/{blog}/feed",
        "labelTemplate": "BDSMLR",
        "titleTemplate": "Open @{blog} following feed"
      },
      "nav_activity": {
        "mode": "internal",
        "pattern": "/{blog}/activity",
        "labelTemplate": "Activity",
        "titleTemplate": "Open @{blog} activity"
      },
      "nav_following": {
        "mode": "internal",
        "pattern": "/following",
        "labelTemplate": "Following",
        "titleTemplate": "Open following timeline"
      },
      "feed_following_list": {
        "mode": "internal",
        "pattern": "/{blog}/social?tab=following",
        "labelTemplate": "Following list",
        "titleTemplate": "Open @{blog} following list"
      },
      "feed_followers_list": {
        "mode": "internal",
        "pattern": "/{blog}/social?tab=followers",
        "labelTemplate": "Followers list",
        "titleTemplate": "Open @{blog} followers list"
      },
      "post_permalink": {
        "mode": "internal",
        "pattern": "/post/{postId}",
        "icon": "\u2197",
        "labelTemplate": "{postId}",
        "titleTemplate": "Open post {postId}"
      },
      "post_origin_blog": {
        "mode": "internal",
        "pattern": "/{blog}/activity",
        "labelTemplate": "@{blog}",
        "titleTemplate": "Open @{blog} activity"
      },
      "post_via_blog": {
        "mode": "internal",
        "pattern": "/{blog}/activity",
        "labelTemplate": "@{blog}",
        "titleTemplate": "Open @{blog} activity"
      },
      "activity_actor_blog": {
        "mode": "internal",
        "pattern": "/{blog}/activity",
        "labelTemplate": "@{blog}",
        "titleTemplate": "Open @{blog} activity"
      },
      "activity_target_post": {
        "mode": "internal",
        "pattern": "/post/{postId}",
        "icon": "\u2197",
        "labelTemplate": "{postId}",
        "titleTemplate": "Open post {postId}"
      },
      "recommendation_post": {
        "mode": "internal",
        "pattern": "/post/{postId}",
        "icon": "\u2197",
        "labelTemplate": "{postId}",
        "titleTemplate": "Open recommended post {postId}"
      },
      "search_tag": {
        "mode": "internal",
        "pattern": "/search?q={tag}",
        "labelTemplate": "#{tag}",
        "titleTemplate": "Search for #{tag}"
      },
      "blog_header_external_blog": {
        "mode": "legacy",
        "pattern": "https://{blog}.bdsmlr.com",
        "target": "_blank",
        "icon": "\u2197",
        "labelTemplate": "Visit",
        "titleTemplate": "Visit @{blog} on legacy site"
      }
    }
  },
  "post_render_policy": {
    "base": {
      "showPermalink": true,
      "showBlogChip": false,
      "compactMetadata": false
    },
    "by_view": {},
    "by_role": {},
    "by_env": {}
  },
  "render": {
    "pages": {
      "archive": {
        "slots": {
          "main_stream": {
            "cards": [
              "post_grid"
            ],
            "async": true,
            "loading": {
              "cardType": "post_grid",
              "count": 12
            }
          }
        }
      },
      "search": {
        "slots": {
          "main_stream": {
            "cards": [
              "post_grid"
            ],
            "async": true,
            "loading": {
              "cardType": "post_grid",
              "count": 8
            }
          }
        }
      },
      "feed": {
        "slots": {
          "main_stream": {
            "cards": [
              "post_feed"
            ],
            "async": true,
            "loading": {
              "cardType": "post_feed",
              "count": 4
            }
          }
        }
      },
      "activity": {
        "slots": {
          "main_stream": {
            "cards": [
              "post_feed"
            ],
            "async": true,
            "loading": {
              "cardType": "post_feed",
              "count": 4
            }
          }
        }
      },
      "lightbox": {
        "slots": {
          "main_stream": {
            "cards": [
              "lightbox_post"
            ]
          }
        }
      },
      "post": {
        "slots": {
          "main_stream": {
            "cards": [
              "post_detail_card"
            ]
          }
        }
      },
      "social": {
        "slots": {
          "main_stream": {
            "cards": [
              "social_blog_list"
            ],
            "async": true,
            "loading": {
              "cardType": "social_blog_list",
              "count": 8
            }
          }
        }
      }
    },
    "cards": {
      "post_grid": {
        "layout": "grid",
        "elements": [],
        "regions": {
          "media": [
            "media_primary"
          ],
          "meta": [
            "meta_minimal",
            "badge_tag_count"
          ]
        },
        "mode_overrides": {
          "regular": {
            "region_order": [
              "media",
              "meta"
            ]
          },
          "admin": {
            "region_order": [
              "header",
              "badges",
              "media",
              "meta",
              "actions"
            ]
          }
        },
        "skeleton": {
          "variant": "post-card",
          "structure": [
            "header_ghost",
            "media_ghost",
            "stats_ghost"
          ],
          "count_policy": {
            "default": 12
          },
          "transition": "swap"
        }
      },
      "post_feed": {
        "layout": "full",
        "elements": [],
        "regions": {
          "header": [
            "context_row"
          ],
          "media": [
            "media_primary"
          ],
          "meta": [
            "meta_compact",
            "badge_tag_count"
          ],
          "actions": [
            "action_permalink"
          ]
        },
        "mode_overrides": {
          "regular": {
            "region_order": [
              "media",
              "meta",
              "actions"
            ]
          },
          "admin": {
            "region_order": [
              "header",
              "badges",
              "media",
              "meta",
              "actions"
            ]
          }
        },
        "skeleton": {
          "variant": "post-feed",
          "structure": [
            "media_ghost",
            "stats_ghost"
          ],
          "count_policy": {
            "default": 4
          },
          "transition": "swap"
        }
      },
      "lightbox_post": {
        "layout": "lightbox",
        "elements": [],
        "regions": {
          "header": [
            "context_row"
          ],
          "media": [
            "media_primary"
          ],
          "meta": [
            "meta_rich",
            "tags_expanded"
          ],
          "badges": [
            "badge_system_deleted",
            "badge_system_tombstone"
          ],
          "actions": [
            "action_permalink",
            "action_context_reblogger",
            "action_context_origin"
          ]
        },
        "mode_overrides": {
          "regular": {
            "region_order": [
              "media",
              "meta",
              "actions"
            ]
          },
          "admin": {
            "region_order": [
              "header",
              "badges",
              "media",
              "meta",
              "actions"
            ]
          }
        }
      },
      "social_blog_list": {
