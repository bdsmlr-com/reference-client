    "gutter": {
      "width": 150,
      "height": 150,
      "gravity": "gravity:sm",
      "resize": "fill"
    },
    "gutter-pixelated": {
      "width": 150,
      "height": 150,
      "gravity": "gravity:sm",
      "resize": "fill",
      "filters": [
        "pix:8"
      ]
    }
  },
  "environments": {
    "dev": {
      "name": "Development",
      "mediaProxyBase": "https://imgproxy.i.bdsmlr.com",
      "imgproxyMode": "unsafe"
    },
    "staging": {
      "name": "Staging",
      "mediaProxyBase": "https://media.i.bdsmlr.com",
      "imgproxyMode": "fixed"
    },
    "prod": {
      "name": "Production",
      "mediaProxyBase": "https://media.bdsmlr.com",
      "imgproxyMode": "fixed"
    }
  },
  "media_behavior": {
    "default": {
      "autoplay": false,
      "controls": false,
      "loop": true,
      "preload": "none"
    },
    "gallery-grid": {
      "autoplay": true,
      "controls": false,
      "loop": true,
      "preload": "metadata"
    },
    "gallery-grid-pixelated": {
      "autoplay": true,
      "controls": false,
