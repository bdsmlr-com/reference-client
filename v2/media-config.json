{
  "presets": {
    "gallery-grid": { "width": 300, "height": 300, "gravity": "gravity:sm", "resize": "fill" },
    "gallery-masonry": { "width": 400, "height": 0, "gravity": "gravity:sm", "resize": "fit" },
    "feed": { "width": 600, "height": 0, "gravity": "gravity:sm", "resize": "fit" },
    "lightbox": { "width": 1200, "height": 0, "gravity": "gravity:sm", "resize": "fit" },
    "poster": { "width": 600, "height": 0, "gravity": "gravity:sm", "resize": "fit", "format": "jpg" },
    "gutter": { "width": 150, "height": 150, "gravity": "gravity:sm", "resize": "fill" }
  },
  "environments": {
    "dev": {
      "name": "Development",
      "mediaProxyBase": "https://imgproxy.i.bdsmlr.com",
      "imgproxyMode": "unsafe"
    },
    "staging": {
      "name": "Staging",
      "mediaProxyBase": "https://imgproxy.i.bdsmlr.com",
      "imgproxyMode": "unsafe"
    },
    "prod": {
      "name": "Production",
      "mediaProxyBase": "https://media.bdsmlr.com",
      "imgproxyMode": "fixed"
    }
  },
  "links": {
    "defaults": {
      "internalTarget": "_self",
      "externalTarget": "_blank",
      "externalRel": ["noopener", "noreferrer"]
    },
    "contexts": {
      "nav_logo": { "mode": "internal", "pattern": "/" },
      "nav_activity": { "mode": "internal", "pattern": "/{blog}/activity" },
      "nav_following": { "mode": "internal", "pattern": "/following" },
      "post_permalink": { "mode": "internal", "pattern": "/post/{postId}" },
      "post_origin_blog": { "mode": "internal", "pattern": "/{blog}/activity" },
      "post_via_blog": { "mode": "internal", "pattern": "/{blog}/activity" },
      "activity_actor_blog": { "mode": "internal", "pattern": "/{blog}/activity" },
      "activity_target_post": { "mode": "internal", "pattern": "/post/{postId}" },
      "recommendation_post": { "mode": "internal", "pattern": "/post/{postId}" },
      "search_tag": { "mode": "internal", "pattern": "/search?q={tag}" },
      "blog_header_external_blog": {
        "mode": "legacy",
        "pattern": "https://{blog}.bdsmlr.com",
        "target": "_blank"
      }
    }
  },
  "post_render_policy": {
    "base": {
      "showPermalink": true,
      "showBlogChip": false,
      "compactMetadata": false
    },
    "by_view": {},
    "by_role": {},
    "by_env": {}
  },
  "render": {
    "pages": {
      "archive": {
        "slots": {
          "main_stream": {
            "cards": ["post_grid"],
            "async": true,
            "loading": { "cardType": "post_grid", "count": 12 }
          }
        }
      },
      "search": {
        "slots": {
          "main_stream": {
            "cards": ["post_grid"],
            "async": true,
            "loading": { "cardType": "post_grid", "count": 8 }
          }
        }
      },
      "feed": {
        "slots": {
          "main_stream": {
            "cards": ["post_feed"],
            "async": true,
            "loading": { "cardType": "post_feed", "count": 4 }
          }
        }
      },
      "activity": {
        "slots": {
          "main_stream": {
            "cards": ["post_feed"],
            "async": true,
            "loading": { "cardType": "post_feed", "count": 4 }
          }
        }
      },
      "lightbox": {
        "slots": {
          "main_stream": {
            "cards": ["lightbox_post"]
          }
        }
      },
      "post": {
        "slots": {
          "main_stream": {
            "cards": ["post_detail_card"]
          }
        }
      },
      "social": {
        "slots": {
          "main_stream": {
            "cards": ["social_blog_list"],
            "async": true,
            "loading": { "cardType": "social_blog_list", "count": 8 }
          }
        }
      }
    },
    "cards": {
      "post_grid": {
        "layout": "grid",
        "elements": [],
        "regions": {
          "media": ["media_primary"],
          "meta": ["meta_minimal", "badge_tag_count"]
        },
        "mode_overrides": {
          "regular": { "region_order": ["media", "meta"] },
          "admin": { "region_order": ["header", "badges", "media", "meta", "actions"] }
        },
        "skeleton": {
          "variant": "post-card",
          "structure": ["header_ghost", "media_ghost", "stats_ghost"],
          "count_policy": { "default": 12 },
          "transition": "swap"
        }
      },
      "post_feed": {
        "layout": "full",
        "elements": [],
        "regions": {
          "header": ["context_row"],
          "media": ["media_primary"],
          "meta": ["meta_compact", "badge_tag_count"],
          "actions": ["action_permalink"]
        },
        "mode_overrides": {
          "regular": { "region_order": ["media", "meta", "actions"] },
          "admin": { "region_order": ["header", "badges", "media", "meta", "actions"] }
        },
        "skeleton": {
          "variant": "post-feed",
          "structure": ["media_ghost", "stats_ghost"],
          "count_policy": { "default": 4 },
          "transition": "swap"
        }
      },
      "lightbox_post": {
        "layout": "lightbox",
        "elements": [],
        "regions": {
          "header": ["context_row"],
          "media": ["media_primary"],
          "meta": ["meta_rich", "tags_expanded"],
          "badges": ["badge_system_deleted", "badge_system_tombstone"],
          "actions": ["action_permalink", "action_context_reblogger", "action_context_origin"]
        },
        "mode_overrides": {
          "regular": { "region_order": ["media", "meta", "actions"] },
          "admin": { "region_order": ["header", "badges", "media", "meta", "actions"] }
        }
      },
      "social_blog_list": {
        "layout": "list",
        "elements": ["social_blog"],
        "regions": {
          "meta": ["social_identity"]
        },
        "mode_overrides": {
          "regular": { "region_order": ["meta"] },
          "admin": { "region_order": ["meta"] }
        },
        "skeleton": {
          "variant": "blog-list",
          "structure": ["row_ghost"],
          "count_policy": { "default": 8 },
          "transition": "swap"
        }
      },
      "social_blog": {
        "layout": "list",
        "elements": [],
        "regions": {
          "meta": ["social_identity"]
        },
        "mode_overrides": {
          "regular": { "region_order": ["meta"] },
          "admin": { "region_order": ["meta"] }
        }
      },
      "gallery_card": {
        "layout": "grid",
        "elements": [],
        "regions": {
          "media": ["media_primary"],
          "meta": ["meta_minimal", "badge_tag_count"]
        },
        "mode_overrides": {
          "regular": { "region_order": ["media", "meta"] },
          "admin": { "region_order": ["header", "badges", "media", "meta"] }
        }
      },
      "timeline_full_card": {
        "layout": "full",
        "elements": [],
        "regions": {
          "header": ["context_row"],
          "media": ["media_primary"],
          "meta": ["meta_compact"],
          "actions": ["action_permalink"]
        },
        "mode_overrides": {
          "regular": { "region_order": ["media", "meta", "actions"] },
          "admin": { "region_order": ["header", "badges", "media", "meta", "actions"] }
        }
      },
      "activity_matrix_card": {
        "layout": "cluster",
        "elements": [],
        "regions": {
          "header": ["activity_cluster_header"],
          "media": ["activity_cluster_tiles"],
          "actions": ["activity_cluster_load_more"]
        },
        "mode_overrides": {
          "regular": { "region_order": ["header", "media", "actions"] },
          "admin": { "region_order": ["header", "badges", "media", "actions"] }
        }
      },
      "lightbox_card": {
        "layout": "lightbox",
        "elements": [],
        "regions": {
          "header": ["context_row"],
          "media": ["media_primary"],
          "meta": ["meta_rich", "tags_expanded"],
          "actions": ["action_permalink"]
        },
        "mode_overrides": {
          "regular": { "region_order": ["media", "meta", "actions"] },
          "admin": { "region_order": ["header", "badges", "media", "meta", "actions"] }
        }
      },
      "post_detail_card": {
        "layout": "full",
        "elements": [],
        "regions": {
          "header": ["context_row"],
          "media": ["media_primary"],
          "meta": ["meta_rich", "tags_expanded"],
          "actions": ["action_permalink", "action_context_reblogger", "action_context_origin"]
        },
        "mode_overrides": {
          "regular": { "region_order": ["header", "media", "meta", "actions"] },
          "admin": { "region_order": ["header", "badges", "media", "meta", "actions"] }
        }
      },
      "social_list_card": {
        "layout": "list",
        "elements": [],
        "regions": {
          "meta": ["social_identity"]
        },
        "mode_overrides": {
          "regular": { "region_order": ["meta"] },
          "admin": { "region_order": ["meta"] }
        }
      }
    },
    "elements": {
      "media_primary": { "primitive": "media", "visibility_rules": { "modes": ["regular", "admin"] } },
      "meta_minimal": { "primitive": "group", "visibility_rules": { "modes": ["regular", "admin"] } },
      "meta_compact": { "primitive": "group", "visibility_rules": { "modes": ["regular", "admin"] } },
      "meta_rich": { "primitive": "group", "visibility_rules": { "modes": ["regular", "admin"] } },
      "context_row": { "primitive": "group", "visibility_rules": { "modes": ["regular", "admin"] } },
      "tags_expanded": { "primitive": "group", "visibility_rules": { "modes": ["regular", "admin"] } },
      "badge_tag_count": { "primitive": "badge", "visibility_rules": { "modes": ["regular", "admin"] } },
      "badge_system_deleted": { "primitive": "badge", "visibility_rules": { "requires_admin": true } },
      "badge_system_tombstone": { "primitive": "badge", "visibility_rules": { "requires_admin": true } },
      "activity_cluster_header": { "primitive": "group", "visibility_rules": { "modes": ["regular", "admin"] } },
      "activity_cluster_tiles": { "primitive": "group", "visibility_rules": { "modes": ["regular", "admin"] } },
      "activity_cluster_load_more": { "primitive": "group", "visibility_rules": { "modes": ["regular", "admin"] } },
      "action_permalink": { "primitive": "link", "visibility_rules": { "modes": ["regular", "admin"] } },
      "action_context_reblogger": { "primitive": "link", "visibility_rules": { "modes": ["regular", "admin"] } },
      "action_context_origin": { "primitive": "link", "visibility_rules": { "modes": ["regular", "admin"] } },
      "social_identity": { "primitive": "group", "visibility_rules": { "modes": ["regular", "admin"] } }
    },
    "interactions": {
      "open_lightbox_post": {
        "type": "open_lightbox",
        "zone": "media"
      },
      "open_recommendation_post": {
        "type": "navigate",
        "linkContext": "recommendation_post",
        "zone": "action"
      }
    }
  }
}
