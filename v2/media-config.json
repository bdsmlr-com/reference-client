{
  "presets": {
    "gallery-grid": {
      "width": 300,
      "height": 300,
      "gravity": "gravity:sm",
      "resize": "fill"
    },
    "gallery-grid-pixelated": {
      "width": 300,
      "height": 300,
      "gravity": "gravity:sm",
      "resize": "fill",
      "filters": [
        "pix:12"
      ]
    },
    "gallery-grid-pixelated-animated": {
      "width": 300,
      "height": 300,
      "gravity": "gravity:sm",
      "resize": "fill",
      "filters": [
        "pix:12"
      ],
      "format": "mp4"
    },
    "gallery-masonry": {
      "width": 400,
      "height": 0,
      "gravity": "gravity:sm",
      "resize": "fit"
