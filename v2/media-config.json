    },
    "lightbox-pixelated-animated": {
      "autoplay": true,
      "controls": true,
      "loop": true,
      "preload": "metadata"
    },
    "post-detail": {
      "autoplay": true,
      "controls": true,
      "loop": true,
      "preload": "metadata"
    },
    "post-detail-pixelated": {
      "autoplay": true,
