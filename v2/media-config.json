{
  "presets": {
    "gallery-grid": { "width": 300, "height": 300, "gravity": "gravity:sm", "resize": "fill" },
    "gallery-masonry": { "width": 400, "height": 0, "gravity": "gravity:sm", "resize": "fit" },
    "feed": { "width": 600, "height": 0, "gravity": "gravity:sm", "resize": "fit" },
    "lightbox": { "width": 1200, "height": 0, "gravity": "gravity:sm", "resize": "fit" },
    "poster": { "width": 600, "height": 0, "gravity": "gravity:sm", "resize": "fit", "format": "jpg" },
    "gutter": { "width": 150, "height": 150, "gravity": "gravity:sm", "resize": "fill" }
  },
  "environments": {
    "dev": {
      "name": "Development",
      "mediaProxyBase": "https://imgproxy.i.bdsmlr.com",
      "imgproxyMode": "unsafe"
    },
    "staging": {
      "name": "Staging",
      "mediaProxyBase": "https://imgproxy.i.bdsmlr.com",
      "imgproxyMode": "unsafe"
    },
    "prod": {
      "name": "Production",
      "mediaProxyBase": "https://media.bdsmlr.com",
      "imgproxyMode": "fixed"
    }
  },
  "links": {
    "defaults": {
      "internalTarget": "_self",
      "externalTarget": "_blank",
      "externalRel": ["noopener", "noreferrer"]
    },
    "contexts": {
      "nav_logo": { "mode": "internal", "pattern": "/" },
      "nav_activity": { "mode": "internal", "pattern": "/{blog}/activity" },
      "nav_following": { "mode": "internal", "pattern": "/following" },
      "post_permalink": { "mode": "internal", "pattern": "/post/{postId}" },
      "post_origin_blog": { "mode": "internal", "pattern": "/{blog}/activity" },
      "post_via_blog": { "mode": "internal", "pattern": "/{blog}/activity" },
      "activity_actor_blog": { "mode": "internal", "pattern": "/{blog}/activity" },
      "activity_target_post": { "mode": "internal", "pattern": "/post/{postId}" },
      "recommendation_post": { "mode": "internal", "pattern": "/post/{postId}" },
      "search_tag": { "mode": "internal", "pattern": "/search?q={tag}" },
      "blog_header_external_blog": {
        "mode": "legacy",
        "pattern": "https://{blog}.bdsmlr.com",
        "target": "_blank"
      }
    }
  }
}
